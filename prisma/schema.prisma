generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  picture   String?  @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedbacks Feedback[]
  cartItems CartItem[]
  wishlist  WishlistItem[]
}

enum Brand {
  Nike
  Adidas
  Puma
  Vans
}

enum Category {
  sneakers
  flats
  Canvas
  heels
}

enum Color {
  white
  red
  green
  black
  blue
}

enum PriceRange {
  cheap
  affordable
  expensive
}

enum ProductStatus {
  available
  unavailable
}

model Product {
  id          BigInt   @id @default(autoincrement())
  name        String
  imgSource   String
  brand       Brand
  category    Category
  color       Color
  description String
  rating      Float
  prices      Json
  priceRange  PriceRange
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  tags        String[]
  status      ProductStatus

  cartItems   CartItem[]
  wishlist    WishlistItem[]
}

model Feedback {
  id        BigInt   @id @default(autoincrement())
  userId    String   @db.Uuid
  topic     String
  rating    Int
  message   String
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_feedbacks_user_id")
}

model CartItem {
  userId    String   @db.Uuid
  productId BigInt
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
  @@index([userId])
}

model WishlistItem {
  userId    String   @db.Uuid
  productId BigInt
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
  @@index([userId])
}